<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.App" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Corporate colors -->
        <item name="colorPrimary">@color/corp_3155</item>
        <item name="colorPrimaryVariant">@color/corp_2216</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/corp_2216</item>
        <item name="colorSecondaryVariant">@color/button_primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:colorBackground">@color/background_color</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Make icons/controls less aggressive by default -->
        <item name="colorControlNormal">@color/nav_icon</item>
        <item name="colorControlActivated">@color/button_primary</item>
        <item name="colorControlHighlight">@color/thread_item_selected_bg</item>
        <item name="fontFamily">@font/gotham_bold</item>
        <item name="android:fontFamily">@font/gotham_bold</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.App.Dialog</item>
    </style>

    <style name="ThemeOverlay.App.Dialog" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_dialog_surface</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="textColorAlertDialogListItem">@color/text_primary</item>
    </style>

</resources>

