<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <ImageView
        android:id="@+id/btnDragOption"
        android:layout_width="28dp"
        android:layout_height="40dp"
        android:padding="4dp"
        android:src="@drawable/ic_drag_handle"
        android:contentDescription="Перетащить" />

    <EditText
        android:id="@+id/etOptionText"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:hint="Вариант"
        android:paddingHorizontal="12dp"
        android:background="@drawable/bg_profile_action_row"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary" />

    <ImageView
        android:id="@+id/btnRemoveOption"
        android:layout_width="34dp"
        android:layout_height="48dp"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:contentDescription="Удалить вариант" />

</LinearLayout>
