<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:background="@drawable/bg_modal_sheet"
    android:paddingHorizontal="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="14dp">

    <View
        android:layout_width="38dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_thread_meta_badge" />

    <TextView
        android:id="@+id/tvActionSheetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Действия"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/actionSheetItemsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical" />

    <TextView
        android:id="@+id/btnActionSheetCancel"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_input_soft"
        android:gravity="center"
        android:text="Отмена"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
