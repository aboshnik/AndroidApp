<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/poll_editor_bg">

    <LinearLayout
        android:id="@+id/topBarCreatePost"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnCreatePostBack"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="Назад"
            android:textColor="@color/button_primary"
            android:textStyle="bold"
            android:background="@drawable/bg_feed_action_button_ripple" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Новая новость"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/btnPublishPost"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="Опубликовать"
            android:textColor="@color/button_primary"
            android:textStyle="bold"
            android:background="@drawable/bg_feed_action_button_ripple" />
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBarCreatePost"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/etPostText"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="top|start"
                android:hint="Напишите новость..."
                android:padding="12dp"
                android:background="@drawable/bg_profile_action_row"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:maxLength="3333"
                android:inputType="textCapSentences|textMultiLine" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnAttachMedia"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Фото/видео"
                    android:textColor="@color/button_primary"
                    android:textStyle="bold"
                    android:background="@drawable/bg_feed_action_button_ripple" />

                <TextView
                    android:id="@+id/btnAttachPoll"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Создать опрос"
                    android:textColor="@color/button_primary"
                    android:textStyle="bold"
                    android:background="@drawable/bg_feed_action_button_ripple" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPollChip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:padding="10dp"
                android:background="@drawable/bg_reply_block"
                android:textColor="@color/text_primary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnClearPoll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Убрать опрос"
                android:textColor="#C62828" />

            <LinearLayout
                android:id="@+id/postMediaContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/postMediaTop"
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_profile_action_row" />

                <LinearLayout
                    android:id="@+id/postMediaBottomRow"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/postMediaBottomLeft"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_profile_action_row" />

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp">

                        <ImageView
                            android:id="@+id/postMediaBottomRight"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:background="@drawable/bg_profile_action_row" />

                        <TextView
                            android:id="@+id/postMediaMoreOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:background="#66000000"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:visibility="gone" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
