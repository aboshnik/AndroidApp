<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99000000">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/sheetTopGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.10" />

    <LinearLayout
        android:id="@+id/createPostSheet"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@drawable/bg_modal_sheet"
        android:elevation="16dp"
        app:layout_constraintTop_toBottomOf="@id/sheetTopGuide"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/topBarCreatePost"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="@android:color/white">

            <TextView
                android:id="@+id/btnCreatePostBack"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:text="Назад"
                android:textColor="@color/button_primary"
                android:textStyle="bold"
                android:background="@android:color/transparent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Новая новость"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/btnPublishPost"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:text="Опубликовать"
                android:textColor="@color/button_primary"
                android:textStyle="bold"
                android:background="@android:color/transparent" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FFE5E7EB" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/etPostText"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/bg_input_soft"
                android:gravity="top|start"
                android:hint="Напишите что-нибудь интересное..."
                android:inputType="textCapSentences|textMultiLine"
                android:maxLength="3333"
                android:padding="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvPostTextCounter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="end"
                android:text="0/3333"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/postPreviewContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#FFF3F8FF"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Предпросмотр"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvPostPreviewText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnAttachMedia"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_action_media"
                    android:gravity="center"
                    android:text="Фото/видео"
                    android:textColor="@android:color/white"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnAttachPoll"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_action_poll"
                    android:gravity="center"
                    android:text="Создать опрос"
                    android:textColor="@android:color/white"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPollChip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_reply_block"
                android:padding="10dp"
                android:textColor="@color/text_primary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnClearPoll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Убрать опрос"
                android:textColor="#C62828"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:padding="10dp"
                android:background="#FFF8FAFC">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/bg_input_soft">

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_event_toggle_icon">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_calendar"
                            android:tint="#FF7C3AED"
                            android:contentDescription="@null" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="Мероприятие"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <Switch
                        android:id="@+id/cbEventCoins"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:trackTint="@color/corp_7541"
                        android:thumbTint="@android:color/white" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/postMediaContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/postMediaTop"
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:background="@drawable/bg_profile_action_row"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:id="@+id/postMediaBottomRow"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/postMediaBottomLeft"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_profile_action_row"
                        android:scaleType="centerCrop" />

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1">

                        <ImageView
                            android:id="@+id/postMediaBottomRight"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_profile_action_row"
                            android:scaleType="centerCrop" />

                        <TextView
                            android:id="@+id/postMediaMoreOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#66000000"
                            android:gravity="center"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        </ScrollView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
