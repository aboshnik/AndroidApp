<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="8dp">

    <!-- Блок изображения (плейсхолдер или одна картинка) -->
    <ImageView
        android:id="@+id/postImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:maxHeight="260dp"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:background="@drawable/bg_feed_card" />

    <TextView
        android:id="@+id/postTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="4dp"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:maxLines="4"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/postMore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:paddingHorizontal="4dp"
        android:text="Подробнее"
        android:textColor="@color/button_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/postDelete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:paddingHorizontal="4dp"
        android:text="Удалить"
        android:textColor="#C62828"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/postDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:paddingHorizontal="4dp"
        android:paddingBottom="8dp"
        android:gravity="end"
        android:textColor="@color/feed_date"
        android:textSize="14sp" />

    <View
        android:id="@+id/postDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:background="#D9DDE3" />
</LinearLayout>
