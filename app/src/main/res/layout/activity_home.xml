<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/poll_editor_bg">

    <LinearLayout
        android:id="@+id/topBarHome"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Главная"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnCreateNews"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="+ Новость"
            android:textColor="@color/button_primary"
            android:textStyle="bold"
            android:background="@drawable/bg_feed_action_button_ripple" />
    </LinearLayout>

    <View
        android:id="@+id/homeDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/poll_editor_divider"
        app:layout_constraintTop_toBottomOf="@id/topBarHome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/homeProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/homeDivider"
        app:layout_constraintBottom_toTopOf="@id/bottomNavHome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/homeEmpty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="18dp"
        android:textColor="@color/text_secondary"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/homeDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHomeFeed"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/homeDivider"
        app:layout_constraintBottom_toTopOf="@id/bottomNavHome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/bottomNavHome"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="10dp"
        android:background="@drawable/bg_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_home"
                android:tint="@color/button_primary"
                android:contentDescription="Главная" />

            <TextView
                android:id="@+id/navHomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Главная"
                android:textColor="@color/button_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navChats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:background="?attr/selectableItemBackgroundBorderless">

            <FrameLayout
                android:layout_width="28dp"
                android:layout_height="24dp">

                <ImageView
                    android:id="@+id/navChatsIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_mail"
                    android:tint="@color/text_secondary"
                    android:contentDescription="Чаты" />

                <TextView
                    android:id="@+id/navChatsBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="16dp"
                    android:minWidth="16dp"
                    android:layout_gravity="top|end"
                    android:gravity="center"
                    android:paddingHorizontal="4dp"
                    android:text="1"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_thread_badge"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/navChatsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Чаты"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/navSettingsIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_settings"
                android:tint="@color/text_secondary"
                android:contentDescription="Настройки" />

            <TextView
                android:id="@+id/navSettingsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Настройки"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/navProfileIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_profile"
                android:tint="@color/text_secondary"
                android:contentDescription="Профиль" />

            <TextView
                android:id="@+id/navProfileText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Профиль"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
