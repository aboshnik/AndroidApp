<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_profile_action_row"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/postCardContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/postCardHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvPostTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvPostImportant"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:text="Важно"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/button_primary"
                android:background="@drawable/bg_tg_chip_selected"
                android:visibility="gone" />
        </LinearLayout>

    <LinearLayout
        android:id="@+id/postMediaContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="228dp">

            <ImageView
                android:id="@+id/postMediaTop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_profile_action_row" />

            <TextView
                android:id="@+id/btnMediaPrev"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:text="‹"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="#66000000"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnMediaNext"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text="›"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="#66000000"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvMediaIndex"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:text="1/1"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="#66000000"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/postMediaBottomRow"
            android:layout_width="match_parent"
            android:layout_height="118dp"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/postMediaBottomLeft"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_profile_action_row" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp">

                <ImageView
                    android:id="@+id/postMediaBottomRight"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_profile_action_row" />

                <TextView
                    android:id="@+id/postMediaMoreOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:background="#66000000"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/postCardBottomBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPostText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="4"
            android:ellipsize="end"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvPollBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:text="Опрос"
            android:textColor="@color/button_primary"
            android:textStyle="bold"
            android:background="@drawable/bg_tg_chip_selected"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/postActionsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnPostDetails"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="Подробнее"
                android:textColor="@color/button_primary"
                android:textStyle="bold"
                android:background="@drawable/bg_feed_action_button_ripple"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnPostPoll"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="Опрос"
                android:textColor="@color/button_primary"
                android:textStyle="bold"
                android:background="@drawable/bg_feed_action_button_ripple"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPostMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    </LinearLayout>

    <ImageView
        android:id="@+id/btnDeletePost"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="bottom|end"
        android:padding="6dp"
        android:src="@drawable/ic_delete_red"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Удалить новость"
        android:visibility="gone" />

</FrameLayout>
