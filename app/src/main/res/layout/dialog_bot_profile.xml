<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <ImageView
        android:id="@+id/ivBotAvatar"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_launcher_simple"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_profile_action_row"
        android:padding="2dp" />

    <TextView
        android:id="@+id/tvBotName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:textSize="18sp" />

    <EditText
        android:id="@+id/etBotDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:minHeight="88dp"
        android:gravity="top|start"
        android:hint="Описание бота"
        android:padding="10dp"
        android:background="@drawable/bg_profile_action_row"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:inputType="textMultiLine|textCapSentences" />

    <LinearLayout
        android:id="@+id/rowOfficial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_profile_action_row"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Официальный бот"
            android:textColor="@color/text_primary" />

        <Switch
            android:id="@+id/swOfficialBot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnChangeBotPhoto"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Изменить фото"
            android:textColor="@color/button_primary"
            android:textStyle="bold"
            android:background="@drawable/bg_feed_action_button_ripple" />

        <TextView
            android:id="@+id/btnSaveBotProfile"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="Сохранить"
            android:textColor="@color/button_primary"
            android:textStyle="bold"
            android:background="@drawable/bg_feed_action_button_ripple" />
    </LinearLayout>

</LinearLayout>
