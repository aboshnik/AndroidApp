<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:background="@drawable/bg_modal_sheet"
    android:paddingHorizontal="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="14dp">

    <View
        android:layout_width="38dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_thread_meta_badge" />

    <TextView
        android:id="@+id/tvPollTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvPollDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/pollOptionsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical" />

    <TextView
        android:id="@+id/btnViewVotes"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_action_media"
        android:gravity="center"
        android:text="Кто проголосовал"
        android:textColor="@color/button_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btnClosePollDialog"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_input_soft"
        android:gravity="center"
        android:text="Закрыть"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
