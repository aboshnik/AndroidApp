<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/bg_profile_card">

    <ImageView
        android:id="@+id/ivPreviewItemPhoto"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:scaleType="centerCrop"
        android:src="@drawable/coin"
        android:contentDescription="Фото товара"
        android:background="@drawable/bg_profile_action_row" />

    <TextView
        android:id="@+id/tvPreviewItemTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:textSize="17sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="Товар" />

    <TextView
        android:id="@+id/tvPreviewItemMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:text="Количество: 0 × 0" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_profile_action_row"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/coin"
            android:contentDescription="Монеты" />

        <TextView
            android:id="@+id/tvPreviewItemLineTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Сумма: 0"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnPreviewItemClose"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="Закрыть"
        android:textColor="@color/button_primary"
        android:textStyle="bold"
        android:background="@drawable/bg_feed_action_button_ripple" />

</LinearLayout>
