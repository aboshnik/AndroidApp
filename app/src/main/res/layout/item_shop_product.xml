<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/bg_profile_card">

    <ImageView
        android:id="@+id/ivProductPhoto"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:src="@drawable/coin"
        android:scaleType="centerInside"
        android:padding="14dp"
        android:background="@drawable/bg_shop_product_media" />

    <TextView
        android:id="@+id/tvProductTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:minHeight="36dp"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvProductDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/text_secondary"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/tvProductStock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/productPriceRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/coin"
            android:contentDescription="Монеты" />

        <TextView
            android:id="@+id/tvProductPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="@color/nav_active"
            android:textStyle="bold"
            android:textSize="14sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

    </LinearLayout>

    <TextView
        android:id="@+id/btnAddToCart"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Купить"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:background="@drawable/bg_shop_buy_btn" />

</LinearLayout>
