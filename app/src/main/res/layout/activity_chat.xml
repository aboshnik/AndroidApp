<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/poll_editor_bg">

    <LinearLayout
        android:id="@+id/topBarChat"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnChatBack"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="Назад"
            android:textColor="@color/button_primary"
            android:textStyle="bold"
            android:background="@drawable/bg_feed_action_button_ripple" />

        <TextView
            android:id="@+id/tvChatTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivChatOfficialBadge"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_verified_badge"
            android:contentDescription="Официальный бот"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnChannelNotifyOn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:visibility="gone"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_notifications_on"
            android:contentDescription="Включить уведомления" />

        <ImageButton
            android:id="@+id/btnChannelNotifyOff"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:visibility="gone"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_notifications_off"
            android:contentDescription="Отключить уведомления" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/messagesProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/topBarChat"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/messagesEmpty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="18dp"
        android:textColor="@color/text_secondary"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topBarChat"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="12dp"
        android:paddingBottom="10dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topBarChat"
        app:layout_constraintBottom_toTopOf="@id/messageComposer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/selectionBar"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="#0F000000"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/messageComposer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvSelectedCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1 выбрано"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnForwardSelected"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="Переслать"
            android:textColor="@color/button_primary"
            android:background="@drawable/bg_feed_action_button_ripple" />

        <TextView
            android:id="@+id/btnDeleteSelected"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="Удалить"
            android:textColor="#C62828"
            android:background="@drawable/bg_feed_action_button_ripple" />

        <TextView
            android:id="@+id/btnCancelSelection"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="Отмена"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_feed_action_button_ripple" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/replyPreview"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="#0A206877"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/messageComposer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvReplyText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Ответ: ..."
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/btnCancelReply"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="✕"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_feed_action_button_ripple" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/mediaDraftPreview"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="10dp"
        android:background="#0A206877"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/messageComposer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivMediaDraftThumb"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            android:background="@drawable/bg_profile_action_row" />

        <TextView
            android:id="@+id/tvMediaDraftLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Вложение"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/btnCancelMediaDraft"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="✕"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_feed_action_button_ripple" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/messageComposer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        android:background="@color/poll_editor_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnAttach"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_attach"
            android:contentDescription="Вложения" />

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_profile_action_row"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:hint="Сообщение"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:gravity="top|start"
            android:maxLines="6"
            android:inputType="textCapSentences|textMultiLine" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_send"
            android:contentDescription="Отправить" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

