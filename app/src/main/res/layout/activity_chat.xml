<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFCFDFE">

    <LinearLayout
        android:id="@+id/topBarChat"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="6dp"
        android:background="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnChatBack"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingHorizontal="6dp"
            android:text="‹"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="24sp"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp">

            <ImageView
                android:id="@+id/ivChatAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_chat_avatar"
                android:clipToOutline="true"
                android:contentDescription="@null"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvChatAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_chat_avatar"
                android:gravity="center"
                android:text="Ч"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="12sp" />

            <View
                android:id="@+id/vChatPresence"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_presence_offline" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvChatTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvChatSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#FF7A8696"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivChatOfficialBadge"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_verified_badge"
            android:contentDescription="Официальный бот"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnChannelNotifyOn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:visibility="gone"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_notifications_on"
            android:contentDescription="Включить уведомления" />

        <ImageButton
            android:id="@+id/btnChannelNotifyOff"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:visibility="gone"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_notifications_off"
            android:contentDescription="Отключить уведомления" />

        <ImageButton
            android:id="@+id/btnChatMenu"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_tg_more_vert"
            android:tint="@color/text_primary"
            android:contentDescription="Меню" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/messagesProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/topBarChat"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/messagesEmpty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="18dp"
        android:textColor="@color/text_secondary"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topBarChat"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/white"
        android:paddingHorizontal="10dp"
        android:paddingBottom="10dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topBarChat"
        app:layout_constraintBottom_toTopOf="@id/messageComposer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/chatDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider_soft"
        app:layout_constraintBottom_toTopOf="@id/messageComposer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/selectionBar"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="@drawable/bg_chat_selection_bar"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/messageComposer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvSelectedCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1 выбрано"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnDeleteSelected"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="Удалить"
            android:textColor="#C62828"
            android:background="@drawable/bg_feed_action_button_ripple" />

        <TextView
            android:id="@+id/btnCancelSelection"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="Отмена"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_feed_action_button_ripple" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/replyPreview"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="#10DCE9F3"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/messageComposer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvReplyText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Ответ: ..."
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnCancelReply"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="✕"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_feed_action_button_ripple" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/mediaDraftPreview"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="10dp"
        android:background="#10DCE9F3"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/messageComposer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivMediaDraftThumb"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            android:background="@drawable/bg_profile_action_row" />

        <TextView
            android:id="@+id/tvMediaDraftLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Вложение"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/btnCancelMediaDraft"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="✕"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_feed_action_button_ripple" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/messageComposer"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnEmoji"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_chat_icon_btn"
            android:src="@android:drawable/ic_menu_recent_history"
            android:tint="@color/text_secondary"
            android:contentDescription="Эмодзи" />

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_chat_composer"
            android:paddingHorizontal="12dp"
            android:hint="Сообщение"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:gravity="center_vertical"
            android:maxLines="4"
            android:inputType="textCapSentences|textMultiLine" />

        <ImageButton
            android:id="@+id/btnAttach"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_chat_icon_btn"
            android:src="@drawable/ic_attach"
            android:tint="@color/icon_tint"
            android:contentDescription="Вложения" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="3dp"
            android:background="@drawable/bg_chat_send_btn"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="@android:color/white"
            android:contentDescription="Голос" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

