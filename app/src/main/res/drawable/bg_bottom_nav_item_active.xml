<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="4dp" android:top="3dp" android:right="4dp" android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFF5F8FF" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item android:width="18dp" android:height="2dp" android:gravity="bottom|center_horizontal">
        <shape android:shape="rectangle">
            <solid android:color="#FF2D7FF0" />
            <corners android:radius="1dp" />
        </shape>
    </item>
</layer-list>
